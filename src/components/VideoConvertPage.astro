---
import VideoConvert from '@components/VideoConvert';
import Privacy from '@components/Privacy.astro';
import LocalProcessingBlock from '@components/LocalProcessingBlock.astro';
import { getLang } from '@i18n/index';
const { locale } = Astro.params;
const l = getLang(locale);
const nav = l.nav;
const t = l.videoConvert;
type FeatureSection = { title: string; body: string };
type FaqItem = { question: string; answer: string };
---

<div class="container py-8 relative z-10 flex-1">
    <h1 class="text-4xl text-center leading-[42px] font-bold mb-1 bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">{t.h1 || nav.videoConvert.title}</h1>
    <p class="text-slate-600 text-center mb-5">{t.tip}</p>
    <div class="pb-12 min-h-[520px]">
        <VideoConvert client:only="react" copy={t.tool} />
    </div>
    <section class="mb-3 rounded-md p-4 bg-sky-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🎬</div>
        <h2 class="text-lg font-bold mb-2">{t.localTitle}</h2>
        <p>{t.localCont1}</p>
        <p>{t.localCont2}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-purple-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">⚙️</div>
        <h2 class="text-lg font-bold mb-2">{t.workflowTitle}</h2>
        <p>{t.workflowCont1}</p>
        <p>{t.workflowCont2}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-green-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🔒</div>
        <h2 class="text-lg font-bold mb-2">{t.privacyTitle}</h2>
        <p>{t.privacyCont1}</p>
        <p>{t.privacyCont2}</p>
    </section>
    <LocalProcessingBlock />
    {t.featureSections && (
        <section class="my-8 rounded-md border border-slate-100 bg-white/80 p-5 shadow-sm">
            <div class="max-w-3xl">
                <h2 class="text-2xl font-extrabold text-slate-800">{t.seoTitle}</h2>
                <p class="mt-3 text-sm leading-7 text-slate-600">{t.seoIntro}</p>
            </div>
            <div class="mt-5 grid gap-3 md:grid-cols-2">
                {t.featureSections.map((item: FeatureSection) => (
                    <article class="rounded-md border border-slate-100 bg-slate-50/70 p-4">
                        <h3 class="text-base font-bold text-slate-800">{item.title}</h3>
                        <p class="mt-2 text-sm leading-6 text-slate-600">{item.body}</p>
                    </article>
                ))}
            </div>
        </section>
    )}
    {t.faqs && (
        <section class="my-8 rounded-md border border-slate-100 bg-white/80 p-5 shadow-sm">
            <h2 class="text-2xl font-extrabold text-slate-800">{t.faqTitle}</h2>
            <div class="mt-4 divide-y divide-slate-100">
                {t.faqs.map((item: FaqItem) => (
                    <details class="group py-3">
                        <summary class="cursor-pointer text-sm font-bold text-slate-800 group-open:text-blue-600">{item.question}</summary>
                        <p class="mt-2 text-sm leading-6 text-slate-600">{item.answer}</p>
                    </details>
                ))}
            </div>
        </section>
    )}
    <Privacy />
    <section class="text-center text-xs text-slate-400 [&_a]:underline">
        Video conversion powered by <a href="https://github.com/ffmpegwasm/ffmpeg.wasm" target="_blank" rel="noopener noreferrer">ffmpeg.wasm</a>. Interaction model adapted from <a href="https://github.com/tejaswigowda/ffmpeg-webCLI" target="_blank" rel="noopener noreferrer">ffmpeg-webCLI</a>.
    </section>
</div>
<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": t.title,
    "description": t.description,
    "operatingSystem": "ALL",
    "applicationCategory": "BrowserApplication",
    "browserRequirements": "requires HTML5, WebAssembly, and modern browser media support",
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
    },
    "featureList": t.featureSections?.map((item: FeatureSection) => item.title) || undefined,
    "keywords": t.keywords
})}/>
{t.faqs && (
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": t.faqs.map((item: FaqItem) => ({
            "@type": "Question",
            "name": item.question,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": item.answer
            }
        }))
    })}/>
)}
