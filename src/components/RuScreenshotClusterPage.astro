---
import { getRelativeLocaleUrl } from 'astro:i18n';

interface ClusterSection {
    title: string;
    body: string[];
}
interface FaqItem {
    question: string;
    answer: string;
}
interface Props {
    page: {
        title: string;
        description: string;
        h1: string;
        eyebrow: string;
        intro: string[];
        sections: ClusterSection[];
        faq: FaqItem[];
    };
}

const { page } = Astro.props;
const mainScreenshotUrl = getRelativeLocaleUrl('ru', '/take-a-screenshot');
---

<div class="container py-8 relative z-10 flex-1">
    <article class="max-w-4xl mx-auto">
        <p class="text-center text-sm font-semibold text-blue-600 mb-2">{page.eyebrow}</p>
        <h1 class="text-4xl text-center leading-[42px] font-bold mb-3 bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">{page.h1}</h1>
        <div class="text-slate-600 text-center text-sm max-w-3xl mx-auto mb-6 [&>p]:mb-2">
            {page.intro.map(item => <p>{item}</p>)}
        </div>
        <div class="flex justify-center mb-10">
            <a href={mainScreenshotUrl} class="inline-flex items-center justify-center rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800">
                Открыть инструмент скриншотов
            </a>
        </div>

        <section class="mb-3 rounded-md p-4 bg-sky-100/40 text-xs [&>p]:mb-1">
            <div class="mb-1 text-sm">▣</div>
            <h2 class="text-lg font-bold mb-2">Главное</h2>
            <p>Эта страница объясняет отдельный сценарий работы со скриншотами. Для создания, вставки, обрезки и сохранения изображения используйте основной инструмент: <a href={mainScreenshotUrl} class="text-blue-600 underline">скриншот онлайн в ShotEasy</a>.</p>
        </section>

        {page.sections.map(section => (
            <section class="mb-3 rounded-md p-4 bg-white/75 text-xs shadow-sm ring-1 ring-slate-200/70 [&>p]:mb-1">
                <h2 class="text-lg font-bold mb-2">{section.title}</h2>
                {section.body.map(item => <p>{item}</p>)}
            </section>
        ))}

        <section class="mb-3 rounded-md p-4 bg-indigo-100/40 text-xs [&>p]:mb-1">
            <div class="mb-1 text-sm">?</div>
            <h2 class="text-lg font-bold mb-2">FAQ</h2>
            {page.faq.map(item => (
                <div class="mb-3 last:mb-0">
                    <h3 class="font-semibold mb-1 text-sm">{item.question}</h3>
                    <p>{item.answer}</p>
                </div>
            ))}
        </section>

        <section class="rounded-md p-4 bg-green-100/40 text-xs">
            <h2 class="text-lg font-bold mb-2">Перейти к инструменту</h2>
            <p class="mb-3">Готовы сделать или отредактировать снимок экрана? Вернитесь на главную страницу инструмента.</p>
            <a href={mainScreenshotUrl} class="inline-flex items-center justify-center rounded-md bg-gray-900 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gray-800">
                Скриншот онлайн
            </a>
        </section>
    </article>
</div>

<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": page.faq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer
        }
    }))
})}/>
<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "Скриншот онлайн",
            "item": new URL(mainScreenshotUrl, Astro.url.origin).toString()
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": page.h1,
            "item": Astro.url.toString()
        }
    ]
})}/>
