---
import LongImageComposer from '@components/LongImageComposer';
import Privacy from '@components/Privacy.astro';
import LocalProcessingBlock from '@components/LocalProcessingBlock.astro';
import SeoContentBlock from '@components/SeoContentBlock.astro';
import ToolStructuredData from '@components/ToolStructuredData.astro';
import { getLang, getLocale } from '@i18n/index';
import { getToolSeoContent } from '@lib/toolSeoContent';
const { locale } = Astro.params;
const lang = getLocale(locale);
const l = getLang(locale);
const nav = l.nav;
const t = l.longImage;
const seoContent = getToolSeoContent(lang, 'longImage', t);
---

<div class="container py-8 relative z-10 flex-1">
    <h1 class="text-4xl text-center leading-[42px] font-bold mb-0.5 bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">{nav.longImage.title}</h1>
    <p class="text-slate-600 text-center mb-2">{t.tip}</p>
    <div class="pb-12 min-h-[300px]">
        <LongImageComposer client:only="react" />
    </div>
    <section class="mb-3 rounded-md p-4 bg-sky-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🧩</div>
        <h2 class="text-lg font-bold mb-2">{t.localTitle}</h2>
        <p>{t.localCont1}</p>
        <p>{t.localCont2}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-pink-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">📐</div>
        <h2 class="text-lg font-bold mb-2">{t.settingTitle}</h2>
        <p>{t.settingCont1}</p>
        <p>{t.settingCont2}</p>
    </section>
    <LocalProcessingBlock />
    <SeoContentBlock content={seoContent} />
    <Privacy />
</div>
<ToolStructuredData
    name={t.title}
    description={t.description}
    keywords={t.keywords}
    locale={lang}
    browserRequirements="Requires HTML5 canvas support"
    featureList={seoContent.featureList}
/>
