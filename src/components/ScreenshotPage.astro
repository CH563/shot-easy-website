---
import Privacy from '@components/Privacy.astro';
import LocalProcessingBlock from '@components/LocalProcessingBlock.astro';
import { getLocale, getLang } from '@i18n/index';
import { getRelativeLocaleUrl } from 'astro:i18n';
import Screenshot from '@components/screenshot/Screenshot';
const { locale } = Astro.params;
const lang = getLocale(locale);
const l = getLang(locale);
const t = l.screenshot;
interface FaqItem {
    question: string;
    answer: string;
}
interface ClusterLink {
    href: string;
    title: string;
    description: string;
}
const faqItems: FaqItem[] = t.faq || [];
const clusterLinks: ClusterLink[] = t.clusterLinks || [];
---

<div class="container py-8 relative z-10 flex-1">
    <h1 class="text-4xl text-center leading-[42px] font-bold mb-0.5 bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">{t.h1 || t.title}</h1>
    <p class="text-slate-600 text-center mb-2">{t.tip}</p>
    {t.intro1 && <p class="text-slate-600 text-center text-sm max-w-3xl mx-auto mb-1">{t.intro1}</p>}
    {t.intro2 && <p class="text-slate-600 text-center text-sm max-w-3xl mx-auto mb-3">{t.intro2}</p>}
    <div class="pb-12 min-h-[320px]">
        <Screenshot client:only="react" />
    </div>
    <section class="mb-3 rounded-md p-4 bg-sky-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🏙️</div>
        <h2 class="text-lg font-bold mb-2">{t.how}</h2>
        <ol class="list-decimal list-inside [&_li]:py-1">
            <li>{t.howCont1}</li>
            <li>{t.howCont2}</li>
            <li>{t.howCont3}</li>
            <li>{t.howCont4}</li>
            <li>{t.howCont5}</li>
            <li>{t.howCont6}</li>
            <li>{t.howCont7}</li>
        </ol>
    </section>
    <section class="mb-3 rounded-md p-4 bg-pink-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🤩</div>
        <h2 class="text-lg font-bold mb-2">{t.why}</h2>
        <p>{t.whyCont1}</p>
        <p>{t.whyCont2}</p>
        <p>{t.whyCont3}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-green-100/40 text-xs [&>p]:mb-1 [&_span]:inline-block [&_span]:rounded-sm [&_span]:bg-black/70 [&_span]:px-1.5 [&_span]:text-white">
        <div class="mb-1 text-sm">📸</div>
        <h2 class="text-lg font-bold mb-2">{t.can}</h2>
        <h3 class="font-semibold mb-1 text-sm">{t.canWin}</h3>
        <p>{t.canWin1}</p>
        <p set:html={t.canWin2} />
        <p set:html={t.canWin3} />
        <h3 class="font-semibold mb-1 text-sm pt-4">{t.canMac}</h3>
        <p>{t.canMac1}</p>
        <h4 class="font-semibold mb-1 pt-2">1.{t.canMacScreen}</h4>
        <p set:html={t.canMacScreen1} />
        <h4 class="font-semibold mb-1 pt-2">2.{t.canMacWin}</h4>
        <p set:html={t.canMacWin1} />
        <h4 class="font-semibold mb-1 pt-2">3.{t.canMacCrop}</h4>
        <p set:html={t.canMacCrop1} />
    </section>
    <LocalProcessingBlock />
    {faqItems.length > 0 && (
        <section class="mb-3 rounded-md p-4 bg-indigo-100/40 text-xs [&>p]:mb-1">
            <div class="mb-1 text-sm">❔</div>
            <h2 class="text-lg font-bold mb-2">{t.faqTitle}</h2>
            {faqItems.map(item => (
                <div class="mb-3 last:mb-0">
                    <h3 class="font-semibold mb-1 text-sm">{item.question}</h3>
                    <p>{item.answer}</p>
                </div>
            ))}
        </section>
    )}
    {clusterLinks.length > 0 && (
        <section class="mb-3 rounded-md p-4 bg-white/75 text-xs shadow-sm ring-1 ring-slate-200/70">
            <h2 class="text-lg font-bold mb-2">{t.clusterTitle}</h2>
            <div class="grid gap-2 md:grid-cols-3">
                {clusterLinks.map(item => (
                    <a href={getRelativeLocaleUrl(lang, item.href)} class="block rounded-md border border-slate-200 bg-white p-3 hover:border-blue-300 hover:text-blue-600">
                        <h3 class="font-semibold mb-1 text-sm">{item.title}</h3>
                        <p class="text-slate-600">{item.description}</p>
                    </a>
                ))}
            </div>
        </section>
    )}
    <Privacy />
</div>
<script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": t.title,
    "description": t.description,
    "operatingSystem": "ALL",
    "applicationCategory": "BrowserApplication",
    "browserRequirements": "requires HTML5 support",
    "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "3.6",
        "ratingCount": "1448",
        "bestRating": "5"
    },
    "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
    }
})}/>
{faqItems.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map(item => ({
            "@type": "Question",
            "name": item.question,
            "acceptedAnswer": {
                "@type": "Answer",
                "text": item.answer
            }
        }))
    })}/>
)}
