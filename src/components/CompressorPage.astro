---
import CompressorInit from '@components/CompressorInit';
import Privacy from '@components/Privacy.astro';
import LocalProcessingBlock from '@components/LocalProcessingBlock.astro';
import SeoContentBlock from '@components/SeoContentBlock.astro';
import ToolStructuredData from '@components/ToolStructuredData.astro';
import { getLang, getLocale } from '@i18n/index';
import { getToolSeoContent } from '@lib/toolSeoContent';
const { locale } = Astro.params;
const lang = getLocale(locale);
const l = getLang(locale);
const nav = l.nav;
const t = l.compressor;
const seoContent = getToolSeoContent(lang, 'compressor', t);
---

<div class="container py-8 relative z-10 flex-1">
    <h1 class="text-4xl text-center leading-[42px] font-bold mb-0.5 bg-gradient-to-r from-gray-600 to-gray-800 bg-clip-text text-transparent">{nav.compressor.title}</h1>
    <p class="text-slate-600 text-center mb-2">{t.tip}</p>
    <div class="pb-12 min-h-[300px]">
        <CompressorInit client:only="react" />
    </div>
    <section class="mb-3 rounded-md p-4 bg-sky-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🏙️</div>
        <h2 class="text-lg font-bold mb-2">{t.online}</h2>
        <p>{t.onlineCont1}</p>
        <p>{t.onlineCont2}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-pink-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🤩</div>
        <h2 class="text-lg font-bold mb-2">{t.why}</h2>
        <p>{t.whyCont1}</p>
        <p>{t.whyCont2}</p>
    </section>
    <section class="mb-3 rounded-md p-4 bg-green-100/40 text-xs [&>p]:mb-1">
        <div class="mb-1 text-sm">🐼</div>
        <h2 class="text-lg font-bold mb-2">{t.vsTitle}</h2>
        <h3 class="text-sm font-bold my-2">{t.vsTitle1}</h3>
        <p>{t.vsCont1}</p>
        <p>{t.vsCont2}</p>
        <p>{t.vsCont3}</p>
        <p>{t.vsCont4}</p>
        <p>{t.vsCont5}</p>
        <h3 class="text-sm font-bold my-2">{t.vsTitle2}</h3>
        <p>{t.vsCont6}</p>
        <p>{t.vsCont7}</p>
        <p>{t.vsCont8}</p>
        <p>{t.vsCont9}</p>
        <p>{t.vsCont10}</p>
        <p>{t.vsCont11}</p>
    </section>
    <LocalProcessingBlock />
    <SeoContentBlock content={seoContent} />
    <Privacy />
</div>
<ToolStructuredData
    name={t.title}
    description={t.description}
    keywords={t.keywords}
    locale={lang}
    browserRequirements="Requires WebAssembly and modern browser file APIs"
    featureList={seoContent.featureList}
/>
