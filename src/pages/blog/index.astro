---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) => new Intl.DateTimeFormat('en', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
}).format(date);
---

<Layout title='ShotEasy Blog - Screenshot and Image Tool Guides' description="Guides, updates, and practical notes about ShotEasy screenshot, image editing, compression, and browser-based tools." languageAlternates={false}>
    <main class="relative overflow-hidden min-h-screen flex flex-col">
        <div class="z-0 absolute w-80 h-60 bg-blue-600 blur-[80px] opacity-30 -top-20 -right-20"></div>
        <div class="z-0 absolute w-80 h-60 bg-blue-400 blur-[80px] opacity-30 top-40 left-40"></div>
        <div class="z-0 absolute w-80 h-60 bg-purple-400 blur-[80px] opacity-30 top-40 right-40"></div>
        <Header />
        <div class="container py-8 relative z-10 flex-1">
            <h1 class="text-3xl text-center font-extrabold">ShotEasy Blog</h1>
            <p class="mx-auto mt-2 max-w-2xl text-center text-sm leading-6 text-slate-600">Practical guides for screenshots, image editing, compression, file conversion, and browser-based productivity tools.</p>
            {posts.length ?
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 p-2 pt-8">
                    {posts.map(post =>(
                        <div class="overflow-hidden flex flex-col gap-2">
                            <a href={`/blog/${post.slug}`} class="block w-full rounded-md shadow-md overflow-hidden aspect-[11/7] bg-slate-50" title={post.data.title}>
                                <img src={post.data.cover || '/image.png'} alt={post.data.coverAlt || post.data.title} class="h-full w-full float-left object-cover transition-all hover:scale-110" />
                            </a>
                            <div class="flex justify-between items-center text-xs text-slate-400 pt-1">
                                <span>{post.data.author}</span>
                                <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
                            </div>
                            <a href={`/blog/${post.slug}`} class="text-xl font-semibold leading-7 hover:underline" title={post.data.title}>{post.data.title}</a>
                            <p class="text-sm leading-6 text-slate-500">{post.data.description}</p>
                            {post.data.tags.length > 0 && (
                                <div class="mt-1 flex flex-wrap gap-1.5">
                                    {post.data.tags.map(tag => <span class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-500">{tag}</span>)}
                                </div>
                            )}
                        </div>
                        )
                    )}
                </div>:
                <div class="text-2xl text-slate-400 text-center font-thin p-10">No articles yet</div>
            }
        </div>
        <Footer showLanguageSwitcher={false} />
    </main>
</Layout>
