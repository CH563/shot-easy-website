---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import BlurBackgroundPage from '@components/BlurBackgroundPage.astro';
import { getLang } from '@i18n/index';
const { locale } = Astro.params;
const t = getLang(locale);
const { title, description, keywords } = t.blurBackground;
---

<Layout title={title} description={description} keywords={keywords}>
    <main class="relative overflow-hidden min-h-screen flex flex-col">
        <div class="z-0 absolute w-80 h-60 bg-cyan-500 blur-[80px] opacity-25 -top-20 -right-20"></div>
        <div class="z-0 absolute w-80 h-60 bg-blue-400 blur-[80px] opacity-25 top-40 left-40"></div>
        <div class="z-0 absolute w-80 h-60 bg-emerald-300 blur-[80px] opacity-25 top-40 right-40"></div>
        <Header />
        <BlurBackgroundPage />
        <Footer />
    </main>
</Layout>
