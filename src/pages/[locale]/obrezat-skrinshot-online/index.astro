---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import RuScreenshotClusterPage from '@components/RuScreenshotClusterPage.astro';
import { ruScreenshotClusterPages } from '@lib/ruScreenshotClusterPages';

const { locale } = Astro.params;
if (locale !== 'ru') {
    return Astro.redirect('/ru/take-a-screenshot', 301);
}

const page = ruScreenshotClusterPages.cropScreenshot;
---

<Layout title={page.title} description={page.description} keywords={page.keywords} languageAlternates={false}>
    <main class="relative overflow-hidden min-h-screen flex flex-col">
        <div class="z-0 absolute w-80 h-60 bg-blue-600 blur-[80px] opacity-30 -top-20 -right-20"></div>
        <div class="z-0 absolute w-80 h-60 bg-blue-400 blur-[80px] opacity-30 top-40 left-40"></div>
        <div class="z-0 absolute w-80 h-60 bg-purple-400 blur-[80px] opacity-30 top-40 right-40"></div>
        <Header />
        <RuScreenshotClusterPage page={page} />
        <Footer showLanguageSwitcher={false} />
    </main>
</Layout>
